#!/usr/bin/env bash
# =============================================================================
# Sovereign Pair — Gitleaks Pre-Push Hook
# =============================================================================
# Scans for secrets before allowing push. Uses local gitleaks binary
# (Organization license) with Docker fallback. Blocks push if ANY leak found.
#
# Install: git config core.hooksPath .githooks
# =============================================================================
set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}🔍 [Gitleaks] Pre-push secret scan...${NC}"

EXIT_CODE=0

# Priority 1: Local gitleaks binary (Organization license)
if command -v gitleaks &>/dev/null; then
    gitleaks detect --source . --no-banner --redact --log-level info --exit-code 1 \
        2>&1 || EXIT_CODE=$?
# Priority 2: Docker fallback
elif command -v docker &>/dev/null && docker info &>/dev/null 2>&1; then
    docker run --rm -v "${REPO_ROOT}:/path:ro" zricethezav/gitleaks:latest \
        detect --source /path --no-banner --redact --log-level info --exit-code 1 \
        2>&1 || EXIT_CODE=$?
else
    echo -e "${YELLOW}⚠️  Neither gitleaks binary nor Docker available — skipping scan${NC}"
    exit 0
fi

if [ "$EXIT_CODE" -ne 0 ]; then
    echo ""
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}  ❌ GITLEAKS: Secrets detected — PUSH BLOCKED${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${YELLOW}  Fix the leaked secrets above before pushing.${NC}"
    echo -e "${YELLOW}  Use git-filter-repo to scrub from history.${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    exit 1
fi

echo -e "${GREEN}✅ [Gitleaks] No secrets found — push authorized.${NC}"
exit 0
