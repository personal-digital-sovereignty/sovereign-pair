# ============================================================================
# SEGURANÇA B2B (Data at Rest)
# ============================================================================
# CHAVE MESTRA ESSENCIAL: Utilizada para Encriptar (AES-256-GCM) 
# as API Keys (OpenAI, Anthropic, Gemini) dentro do banco de dados (Envelope Encryption).
# Como gerar uma forte no terminal (Linux/Mac):
#   openssl rand -base64 32
#
SOVEREIGN_MASTER_KEK=

# ============================================================================
# CONFIGURAÇÃO DE PROVIDERS DE IA E CHAVES DE API
# ============================================================================

# Define qual provedor de LLM e de Embeddings usar
# Opções: ollama, openai, anthropic, groq, gemini
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama

# ----- CHAVES DE API EXTERNAS (Necessário apenas se não usar 'ollama') -----
OPENAI_API_KEY=sua_chave_openai_aqui
ANTHROPIC_API_KEY=sua_chave_anthropic_aqui
GROQ_API_KEY=sua_chave_groq_aqui
GEMINI_API_KEY=sua_chave_gemini_aqui

# ============================================================================
# CONFIGURAÇÃO DO OLLAMA (Se LLM_PROVIDER ou EMBEDDING_PROVIDER == 'ollama')
# ============================================================================

# URL do servidor Ollama
# (Por padrão "http://localhost:11434")
# Se usar remotamente ex: "http://192.168.1.100:11434"
# IMPORTANTE: Para acessar remotamente, o servidor Ollama deve estar rodando
# com a variável de ambiente OLLAMA_HOST="0.0.0.0"
# (ex: `OLLAMA_HOST=0.0.0.0 ollama serve`)
OLLAMA_BASE_URL=http://localhost:11434

# Modelo de linguagem (LLM) para chat e geração de respostas
# Execute 'ollama list' para ver modelos disponíveis
# Ou use 'python setup.py' para configuração interativa
#
# Modelos populares:
# - llama3.2 (recomendado): Rápido e eficiente
# - llama3.1: Versão anterior, muito capaz
# - mistral: Excelente para tarefas gerais
# - mixtral: Modelo grande, muito poderoso
# - phi: Modelo pequeno, rápido
# - gemma: Modelo do Google
LLM_MODEL=llama3.2

# Capacidade de Janela de Contexto (Context Window) do Ollama
# Define o tamanho exato da memória de tokens (KV Cache) pre-alocada na VRAM/RAM.
# IMPORTANTE: Ajuste estritamente com base na Memória RAM da sua máquina (Host)!
# - Máquinas Locais Básicas (8GB a 16GB RAM): 4096 a 8192 tokens
# - Oracle A1 Standard (4 Cores / 24GB RAM): 16384 (16k tokens)
# - Oracle A1 Plus (6 Cores / 32GB RAM): 24576 a 32768 (24k a 32k tokens)
#
# Dica PRO: Modelos de 32B (ex: Qwen 2.5 32B GGUF) ocupam ~19GB na RAM.
# Configure 24576 para deixar ~7GB de folga isolada para o Kernel OS e o Embedding Model estático.
OLLAMA_NUM_CTX=8192
# Modelo de embeddings para vetorização de documentos
# Recomendado: nomic-embed-text (funciona bem com todos os LLMs)
#
# Alternativas:
# - mxbai-embed-large: Maior qualidade, mais lento
# - all-minilm: Mais rápido, menor qualidade
#
# IMPORTANTE: O embed model deve estar instalado no Ollama
# Execute: ollama pull bge-m3
EMBED_MODEL=bge-m3

# Timeout para requisições ao Ollama (em segundos)
# Ajuste baseado no tamanho do modelo e hardware
#
# Recomendações por categoria de modelo:
# - Modelos pequenos (<7B parâmetros): 60-90s
#   Exemplos: phi, gemma:2b, llama3.2:1b
#
# - Modelos médios (7B-13B parâmetros): 120-150s
#   Exemplos: llama3.2, llama3.1, mistral, gemma:7b
#
# - Modelos grandes (>13B parâmetros): 180-240s
#   Exemplos: mixtral, llama3:70b, qwen:72b
#
# Se você tiver GPU potente, pode reduzir estes valores
# Se estiver usando apenas CPU, pode precisar aumentar
REQUEST_TIMEOUT=120.0

# ============================================================================
# CAMINHOS DE INGESTÃO (Opcional)
# ============================================================================

# Caminhos customizados para documentos
# Deixe vazio para usar os diretórios padrão (data/raw_docs e data/vault)
# 
# Você pode:
# 1. Apontar para caminhos absolutos (ex: seu Obsidian vault)
# 2. Usar links simbólicos nas pastas padrão
# 3. Deixar vazio e usar as pastas padrão
#
# Exemplos:
# - Obsidian vault: /home/usuario/Documents/ObsidianVault
# - Múltiplos caminhos: /path/1,/path/2,/path/3 (separados por vírgula)

# Caminho para vault/anotações (ex: Obsidian)
# Se vazio, usa data/vault/
VAULT_PATH=

# Caminhos para documentos (PDFs, DOCX, etc)
# Se vazio, usa data/raw_docs/
# Aceita múltiplos caminhos separados por vírgula
RAW_DOCS_PATHS=

# Seguir links simbólicos durante ingestão (true/false)
# Recomendado: true para permitir symlinks
FOLLOW_SYMLINKS=true

# Extensões de arquivo permitidas para ingestão (separadas por vírgula)
# Padrão: .md,.pdf,.txt,.docx,.csv,.json,.html
# 
# Formatos suportados nativamente:
# - .md (Markdown com chunking inteligente)
# - .pdf (documentos PDF)
# - .txt (texto simples)
# - .docx (Microsoft Word moderno)
# - .csv (planilhas)
# - .json (dados estruturados)
# - .html (páginas web)
#
# Formatos NÃO suportados nativamente (requerem conversão):
# - .doc (Word antigo) -> converter para .docx
# - .odt (OpenDocument) -> converter para .docx
#
# Veja docs/FILE_FORMATS.md para mais detalhes sobre conversão
ALLOWED_EXTENSIONS=.md,.pdf,.txt,.docx,.csv,.json,.html

# ============================================================================
# CONFIGURAÇÕES DE CHUNKING
# ============================================================================

# Tamanho máximo de cada bloco de texto (em caracteres)
# Ajustado para compatibilidade com modelo de embeddings
# Padrão: 1024 (compatível com nomic-embed-text)
#
# Valores recomendados por modelo:
# - nomic-embed-text: 1024 (padrão)
# - mxbai-embed-large: 512
# - all-minilm: 256
#
# IMPORTANTE: Chunks muito grandes causam erro "input length exceeds context length"
CHUNK_SIZE=1024

# Sobreposição entre chunks consecutivos (em caracteres)
# Mantém contexto entre blocos adjacentes
# Padrão: 200
#
# Benefícios:
# - Preserva informações nas bordas dos chunks
# - Melhora recuperação de informações
# - Evita perda de contexto
CHUNK_OVERLAP=200

# ============================================================================
# CONFIGURAÇÃO DO CHROMADB
# ============================================================================

# Nome da coleção no ChromaDB
# Use nomes descritivos para diferentes projetos
#
# Exemplos:
# - sovereign_knowledge (padrão)
# - my_project_docs
# - research_papers
# - code_documentation
#
# IMPORTANTE: Cada coleção é independente
# Você pode ter múltiplas coleções para diferentes propósitos
CHROMA_COLLECTION_NAME=sovereign_knowledge

# ------------------------------------------------------------------------------
# 5. PERSONALIZAÇÃO DO ASSISTENTE
# ------------------------------------------------------------------------------
# Define como o AI tratará o usuário e qual tom utilizará
USER_NAME="Jeferson"
ASSISTANT_PERSONA="feminina" # Ex: feminina, masculina, neutra, robótica

# ============================================================================
# CONFIGURAÇÃO DO AGENTE
# ============================================================================

# Modo verbose (true/false)
# - true: Mostra o raciocínio do agente (útil para debug)
# - false: Mostra apenas as respostas finais (mais limpo)
#
# Recomendação: true durante desenvolvimento, false em produção
AGENT_VERBOSE=true

# Máximo de resultados de busca web
# Quantidade de resultados que o DuckDuckGo retornará
#
# Recomendações:
# - 3: Rápido, suficiente para maioria dos casos
# - 5: Mais contexto, um pouco mais lento
# - 10: Máximo contexto, mais lento
MAX_WEB_SEARCH_RESULTS=3

# ============================================================================
# ORQUESTRAÇÃO CÍBRIDA (N8N & REDIS)
# ============================================================================

# Tailnet FQDN para o N8N (Obriga a validação de Certificado TLS Let's Encrypt gerado pelo Sidecar)
# Evita roteamentos vazados pela Ingress Pública da VM original (Darknet Mode)
N8N_HOST=n8n.tailnet.ts.net

# Credenciais de acesso ao Banco de Dados Relacional Híbrido 
# Compartilhado entre a FastApi (Auditoria de Sessões RAG) e o N8N
POSTGRES_USER=sovereign
POSTGRES_PASSWORD=master_pwd
POSTGRES_DB=sovereign_db
GENERIC_TIMEZONE=America/Sao_Paulo

# ============================================================================
# GATEKEEPER E ZERO-TRUST BOUNDARIES
# ============================================================================

# Token de autenticação One-Off Efêmero ou Reusable para associar o Mesh Node.
# Obtenha em https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-auth-xxxxxxxxx

