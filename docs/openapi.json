    "/v1/feedback": {
      "post": {
        "summary": "Save Feedback",
        "description": "Grava o Thumbs Up / Down ou comentário de correção no Database para a AI.",
        "operationId": "save_feedback_v1_feedback_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FeedbackRequest"
              }
            }
          },
          "required": true
