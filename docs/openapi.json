    "/v1/upload": {
      "post": {
        "summary": "Upload Document",
        "description": "Ingests a single document on-the-fly into ChromaDB.\nHandles deduplication using SHA256. \nReturns 'conflict' if a file with the same name but different content exists.",
        "operationId": "upload_document_v1_upload_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_document_v1_upload_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
