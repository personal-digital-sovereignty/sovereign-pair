    "/v1/auth/status": {
      "get": {
        "tags": [
          "Authentication"
        ],
        "summary": "Auth Status",
        "description": "Rota pública para a Web-UI saber se manda o usuário para /setup ou /login",
        "operationId": "auth_status_v1_auth_status_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
