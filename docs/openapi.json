              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/sessions": {
      "get": {
        "summary": "Get All Sessions",
        "description": "Lista todas as conversas gravadas no SQLite.",
        "operationId": "get_all_sessions_v1_sessions_get",
