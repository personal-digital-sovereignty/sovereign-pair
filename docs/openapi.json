{
  "openapi": "3.1.0",
  "info": {
    "title": "Sovereign Pair RAG API",
    "description": "Interface REST para o núcleo RAG local-first e híbrido de Nuvem.",
    "version": "3.0.0"
  },
  "paths": {
    "/v1/auth/setup": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Setup System",
        "description": "Chamada da UI de Oboarding - Roda 1 única vez para travar a base",
        "operationId": "setup_system_v1_auth_setup_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetupRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/auth/login": {
      "post": {
        "tags": [
          "Authentication"
