  "components": {
    "schemas": {
      "Body_upload_document_v1_upload_post": {
        "properties": {
          "file": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "File"
          },
          "force_overwrite": {
            "type": "boolean",
            "title": "Force Overwrite",
            "default": false
          },
          "rename_if_exists": {
            "type": "boolean",
            "title": "Rename If Exists",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_upload_document_v1_upload_post"
      },
      "ChatMessageModel": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "role": {
            "type": "string",
            "title": "Role"
          },
          "content": {
            "type": "string",
            "title": "Content"
          },
          "thumbs_up": {
            "type": "boolean",
            "title": "Thumbs Up"
          },
          "thumbs_down": {
            "type": "boolean",
            "title": "Thumbs Down"
          }
        },
        "type": "object",
        "required": [
          "id",
          "role",
          "content",
          "thumbs_up",
          "thumbs_down"
        ],
        "title": "ChatMessageModel"
      },
      "ChatRequest": {
        "properties": {
          "message": {
            "type": "string",
            "title": "Message",
            "description": "A mensagem ou pergunta enviada pelo usuário"
          },
          "stream": {
            "type": "boolean",
            "title": "Stream",
            "description": "Se deseja que a resposta seja em streaming usando Server-Sent Events (SSE)",
            "default": true
          },
          "active_document": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Active Document",
            "description": "Opcional: O conteúdo do documento que o usuário está visualizando no momento"
          },
          "session_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Session Id",
            "description": "Opcional: ID da sessão SQLite para vincular a conversa a um histórico existente"
          },
          "provider": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Provider",
            "description": "Opcional: ID do provedor na Nuvem (openai, anthropic, ollama, groq)"
          },
          "model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model",
            "description": "Opcional: Nome do modelo do LLM a ser invocado na Nuvem"
          }
        },
        "type": "object",
        "required": [
          "message"
        ],
        "title": "ChatRequest"
      },
      "FeedbackRequest": {
        "properties": {
          "message_id": {
            "type": "integer",
            "title": "Message Id",
            "description": "ID da mensagem da IA a ser avaliada"
          },
          "thumbs_up": {
            "type": "boolean",
            "title": "Thumbs Up",
            "default": false
          },
          "thumbs_down": {
            "type": "boolean",
            "title": "Thumbs Down",
            "default": false
          },
          "feedback_text": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Feedback Text"
          }
        },
        "type": "object",
        "required": [
          "message_id"
        ],
        "title": "FeedbackRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "LoginRequest": {
        "properties": {
          "password": {
            "type": "string",
            "title": "Password"
          }
        },
        "type": "object",
        "required": [
          "password"
        ],
        "title": "LoginRequest"
      },
      "SessionResponse": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "folder_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
