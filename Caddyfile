# --- Sovereign Pair RAG: Caddy Edge Router ---
#
# Este arquivo configura o Caddy como um Proxy Reverso e terminação TSL/SSL automática.
# Ele substitui a necessidade do Nginx + Certbot/Cert-Manager para HTTPS no Docker Compose.

# 1. Configuração para Domínio Público (Descomente e mude o domínio se for expor na internet)
# seudominio.com.br {
#     # Proxy para o Backend FastAPI (Rotas da API REST e SWAGGER UI)
#     reverse_proxy /api/* sovereign-api:8000
#     reverse_proxy /docs* sovereign-api:8000
#     reverse_proxy /openapi.json sovereign-api:8000
#
#     # Todo o resto vai para o Frontend (Nginx Estático servindo Vue SPA)
#     reverse_proxy * sovereign-web:80
# }

# 2. Rotas Comuns (Snippet)
(app_routes) {
    # Proxy para o Backend (O Caddy resolve o nome dns "sovereign-api" da rede Docker)
    handle_path /api/* {
        reverse_proxy sovereign-api:8000
    }
    
    # Rota de Orquestração N8N via Tailnet HTTPS.
    # Ex: n8n.sovereign.ts.net irá carregar a interface da Automation.
    handle /n8n/* {
        uri strip_prefix /n8n
        reverse_proxy sovereign-n8n:5678 {
            header_up Host {upstream_hostport}
        }
    }

    # Rota direta para APIs do Obsidian (/v1/*) que não mandam o prefixo /api/
    # Usamos handle em vez de handle_path para não arrancar o /v1 (FastAPI precisa dele)
    handle /v1/* {
        reverse_proxy sovereign-api:8000
    }
    
    # Swagger UI necessita de caminhos exatos
    reverse_proxy /docs* sovereign-api:8000
    reverse_proxy /openapi.json sovereign-api:8000

    # Catch-All: Roteia o tráfego não-API para o Web UI
    reverse_proxy * sovereign-web:80
}

# 3. Configuração Local Host (HTTPS com Auto-Assinatura Interna)
https://localhost {
    tls internal
    import app_routes
}

# 4. Configuração Subnet Routing (HTTPS MagicDNS Proxy via Tailscale Serve)
# A terminação TLS com Certificados Let's Encrypt "Cadeado Verde" é feita nativamente 
# pelo contêiner do Tailscale utilizando a função interna 'tailscale serve'.
http:// {
    import app_routes
}
